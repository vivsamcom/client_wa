NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Meta webhook verification and Graph API
META_VERIFY_TOKEN=change-me-local-verify-token
META_APP_SECRET=
META_ACCESS_TOKEN=replace-with-temporary-or-system-user-token
META_PHONE_NUMBER_ID=replace-with-phone-number-id
META_API_VERSION=v23.0

# Queue: LavinMQ over AMQP
QUEUE_PROVIDER=lavinmq
QUEUE_URI=amqp://guest:guest@lavinmq:5672
WHATSAPP_INCOMING_QUEUE=wa.incoming.messages
QUEUE_CONCURRENCY=5

# Choose: postgres or mongo
DB_PROVIDER=postgres
DB_URI=postgresql://postgres:postgres@postgres:5432/client_wa
MONGODB_DB=client_wa

# Security / ops
ENABLE_SIGNATURE_VALIDATION=false
LOG_LEVEL=info
