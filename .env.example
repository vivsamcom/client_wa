NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Meta webhook verification and Graph API
VERIFY_TOKEN=change-me-local-verify-token
META_APP_SECRET=
WHATSAPP_TOKEN=replace-with-temporary-or-system-user-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id
GRAPH_API_VERSION=v23.0

# Queue: BullMQ over Redis
QUEUE_URL=redis://redis:6379
QUEUE_NAME=wa.incoming.messages
QUEUE_CONCURRENCY=5

# Choose: postgres or mongo
DB_PROVIDER=postgres
DATABASE_URL=postgres://wa_user:wa_password@postgres:5432/wa_loan_demo
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=wa_loan_demo

# Security / ops
ENABLE_SIGNATURE_VALIDATION=false
LOG_LEVEL=info
