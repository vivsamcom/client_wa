NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://your-render-service.onrender.com

# Meta webhook verification and Graph API
VERIFY_TOKEN=replace-with-render-secret
META_APP_SECRET=replace-with-render-secret
WHATSAPP_TOKEN=replace-with-render-secret
WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id
GRAPH_API_VERSION=v23.0

# Queue: Upstash Redis using BullMQ
QUEUE_URL=rediss://default:<password>@<host>:<port>
QUEUE_NAME=wa.incoming.messages
QUEUE_CONCURRENCY=5

# Default database: Neon PostgreSQL
DB_PROVIDER=postgres
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Optional MongoDB Atlas mode
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>
MONGODB_DB=wa_loan_demo

# Security / ops
ENABLE_SIGNATURE_VALIDATION=true
LOG_LEVEL=info
