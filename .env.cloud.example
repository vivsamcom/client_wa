NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://your-render-service.onrender.com

# Meta webhook verification and Graph API
META_VERIFY_TOKEN=replace-with-render-secret
META_APP_SECRET=replace-with-render-secret
META_ACCESS_TOKEN=replace-with-render-secret
META_PHONE_NUMBER_ID=replace-with-phone-number-id
META_API_VERSION=v23.0

# Queue: CloudAMQP/LavinMQ over AMQP
QUEUE_PROVIDER=lavinmq
QUEUE_URI=amqps://<user>:<password>@<host>/<vhost>
WHATSAPP_INCOMING_QUEUE=wa.incoming.messages
QUEUE_CONCURRENCY=5

# Default database: Supabase PostgreSQL
DB_PROVIDER=postgres
DB_URI=postgresql://<user>:<password>@<host>:5432/postgres?sslmode=require

# Optional MongoDB Atlas mode
MONGODB_DB=client_wa

# Security / ops
ENABLE_SIGNATURE_VALIDATION=true
LOG_LEVEL=info
